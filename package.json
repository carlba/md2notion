{
  "name": "md2notion",
  "description": "Convert a Markdown file to a Notion page using @tryfabric/martian",
  "version": "0.0.1",
  "private": false,
  "license": "UNLICENSED",
  "type": "module",
  "author": "carlba",
  "homepage": "https://github.com/carlba/md2notion",
  "bugs": {
    "url": "https://github.com/carlba/md2notion"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:carlba/md2notion"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "md2notion": "tsx src/md2notion.ts",
    "md2notion:native": "tsx src/md2notion-native.ts",
    "md2notion:markdown": "tsx src/md2notion-markdown.ts",
    "start:dev": "nodemon -r dotenv/config -q src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dependency:update": "npx ncu -u -x eslint"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.3",
    "@types/node": "^25.0.3",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "nodemon": "^3.1.11",
    "npm-check-updates": "^19.3.1",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@notionhq/client": "^5.15.0"
  }
}
