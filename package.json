{
  "name": "md2notion",
  "description": "Convert a Markdown file to a Notion page using @tryfabric/martian",
  "version": "0.0.1",
  "private": false,
  "license": "UNLICENSED",
  "type": "module",
  "author": "carlba",
  "homepage": "https://github.com/carlba/md2notion",
  "bugs": {
    "url": "https://github.com/carlba/md2notion"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:carlba/md2notion"
  },
  "scripts": {
    "build": "tsc",
    "webui": "tsx src/webui-server.ts",
    "md2notion:native": "tsx src/md2notion-native.ts",
    "md2notion:markdown": "tsx src/md2notion-markdown.ts",
    "start:dev": "tsx --env-file-if-exists=.env --watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dependency:update": "npx ncu -u",
    "build-watch": "tsc --watch",
    "start": "node --env-file-if-exists='.env' dist/index.js",
    "linux:install": "docker run --rm --platform linux/amd64 -v \"$PWD\":/app -w /app node:24-bullseye npm install",
    "linux:ci": "docker run --rm --platform linux/amd64 -v \"$PWD\":/app -w /app node:24-bullseye bash -lc \"npm ci && npm run lint && npm test && npm run build\""
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tsconfig/node24": "24.0.4",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "dotenv": "^17.2.3",
    "eslint": "10.2.1",
    "nodemon": "^3.1.11",
    "npm-check-updates": "21.0.3",
    "prettier": "3.8.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0",
    "vitest": "4.1.5"
  },
  "dependencies": {
    "@notionhq/client": "^5.15.0",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "zod": "4.3.6"
  },
  "templater": {
    "managedDependencies": [
      "pino",
      "pino-pretty",
      "zod"
    ],
    "managedDevDependencies": [
      "eslint",
      "@eslint/js",
      "@tsconfig/node24",
      "@types/node",
      "@vitest/coverage-v8",
      "npm-check-updates",
      "prettier",
      "tsx",
      "typescript",
      "typescript-eslint",
      "vitest"
    ]
  }
}
